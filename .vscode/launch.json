{
    "version": "0.2.0",
    "configurations": [
        {
            // F5 on any .cs file in samples/ to build + debug it.
            // The preLaunchTask packs Grape.Graphics into the local feed and
            // builds the file as a file-based app to a deterministic folder.
            "name": "Debug current sample",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-current-sample",
            "program": "dotnet",
            "args": [
                "exec",
                "${fileDirname}/bin/runfile/${fileBasenameNoExtension}/${fileBasenameNoExtension}.dll"
            ],
            "cwd": "${fileDirname}",
            "console": "integratedTerminal",
            "stopAtEntry": false,
            "justMyCode": false
        }
    ]
}
