{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "pack-blitter",
            "type": "shell",
            "command": "dotnet",
            "args": [
                "build",
                "${workspaceFolder}/src/Blitter.Package/Blitter.Package.csproj",
                "-c",
                "Debug",
                "--nologo"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": "$msCompile",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        },
        {
            "label": "build-current-sample",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/.vscode/build-sample.ps1",
                "-File",
                "${file}"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "dependsOn": "pack-blitter",
            "dependsOrder": "sequence",
            "problemMatcher": "$msCompile",
            "group": { "kind": "build", "isDefault": true },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": false
            }
        }
    ]
}
