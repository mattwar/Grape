# Default: normalize text files to LF in repo, check out native on Windows
* text=auto eol=crlf

# Source files — explicit text
*.cs       text diff=csharp
*.csproj   text
*.sln      text eol=crlf
*.props    text
*.targets  text
*.json     text
*.yml      text eol=lf
*.yaml     text eol=lf
*.md       text
*.txt      text
*.xml      text
*.config   text
*.editorconfig text
*.gitignore text
*.gitattributes text

# Shell scripts must always be LF
*.sh   text eol=lf
*.ps1  text eol=crlf

# Git hooks (extension-less shell scripts) must be LF for Git's bash to run them
.githooks/pre-commit text eol=lf
.githooks/pre-push   text eol=lf
.githooks/commit-msg text eol=lf

# Shaders
*.hlsl  text
*.glsl  text
*.vert  text
*.frag  text
*.comp  text
*.spv   binary

# Binary assets
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.bmp   binary
*.ico   binary
*.wav   binary
*.mp3   binary
*.ogg   binary
*.dll   binary
*.exe   binary
*.pdb   binary
*.nupkg binary
*.snupkg binary
*.zip   binary
