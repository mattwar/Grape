<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Verifies that every file-based sample in this folder still compiles
    against the current Blitter package. Adding this project to the
    solution makes `dotnet build src/Blitter.sln` (and Visual Studio's
    Build Solution) also build the samples.

    How it works:
      1. The ProjectReference on Blitter.Package builds it; Blitter.Package has
         GeneratePackageOnBuild=true, so a fresh .nupkg appears in
         artifacts/nuget automatically.
      2. Runs `dotnet build` on each .cs sample file. The samples'
         `#:package Blitter@*-*` resolves to the just-packed version.

    The work is gated by a stamp file with Inputs/Outputs, so it's skipped
    when neither the Blitter sources nor the sample sources have changed.

    To opt out for a single build:
        dotnet build src/Blitter.sln /p:VerifySamples=false
  -->

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
    <NoWarn>$(NoWarn);NU1503</NoWarn>
    <VerifySamples Condition=" '$(VerifySamples)' == '' ">true</VerifySamples>
  </PropertyGroup>

  <ItemGroup>
    <!-- Ensure Blitter.Package is built before we try to pack it. -->
    <ProjectReference Include="..\src\Blitter.Package\Blitter.Package.csproj"
                      ReferenceOutputAssembly="false"
                      Private="false"
                      SkipGetTargetFrameworkProperties="true" />
  </ItemGroup>

  <Target Name="VerifySamples"
          AfterTargets="Build"
          Condition=" '$(VerifySamples)' == 'true' "
          Inputs="@(Compile);$(MSBuildThisFileFullPath);..\src\Blitter.Package\Blitter.Package.csproj;@(SampleFile);@(BlitterSource)"
          Outputs="$(IntermediateOutputPath)samples.verified.stamp">

    <ItemGroup>
      <SampleFile Include="$(MSBuildThisFileDirectory)*.cs" />
      <BlitterSource Include="$(MSBuildThisFileDirectory)..\src\**\*.cs"
                   Exclude="$(MSBuildThisFileDirectory)..\src\**\bin\**;$(MSBuildThisFileDirectory)..\src\**\obj\**" />
    </ItemGroup>

    <!--
      Pass /force-style flags so NuGet re-evaluates the floating "any
      prerelease" version. Without this the file-based runner's hashed
      temp restore is sticky and can resolve to a stale cached version
      of Blitter.
    -->
    <Message Importance="high" Text="Building sample %(SampleFile.Filename).cs..." />
    <Exec Command="dotnet build &quot;%(SampleFile.Identity)&quot; -c $(Configuration) --force --nologo -v quiet"
          WorkingDirectory="$(MSBuildThisFileDirectory)" />

    <MakeDir Directories="$(IntermediateOutputPath)" />
    <Touch Files="$(IntermediateOutputPath)samples.verified.stamp" AlwaysCreate="true" />
  </Target>

</Project>
