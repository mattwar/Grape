<?xml version="1.0" encoding="utf-8"?>
<!--
  Sample-local NuGet configuration.

  When you run a file-based app (`dotnet run TriangleSwarm.cs`) from this folder,
  the .NET SDK picks up this NuGet.config and adds the local artifacts feed in
  addition to nuget.org. That lets the samples reference `Grape.Graphics` from
  a locally-built .nupkg before the real package is published.

  To populate the local feed, build the package project (it packs on build):

      dotnet build ../src/Grape.Graphics/Grape.Graphics.csproj

  This drops a fresh timestamped .nupkg into ../artifacts/nuget; samples
  using `#:package Grape.Graphics@*-*` will pick it up automatically.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="local" value="../artifacts/nuget" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
